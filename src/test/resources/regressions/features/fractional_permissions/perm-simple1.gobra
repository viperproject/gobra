package main

requires acc(i, perm(1, 2))
requires acc(i, perm(1, 4) + perm(1, 4))
ensures acc(i, writePerm)
func test1(i *int) {
	return
}

requires p > noPerm
requires acc(i, p)
ensures acc(i, p)
func test2(i *int, ghost p perm) int {
	return *i
}

requires p > perm(1, 2)
requires acc(i, p)
ensures acc(i, perm(1, 2))
func test3(i *int, ghost p perm) int {
	return *i
}

requires p == writePerm
requires acc(i, p)
ensures acc(i, p)
func test4(i *int, v int, ghost p perm) {
	*i = v
}

requires acc(i, writePerm)
ensures acc(i, writePerm)
func test5(i *int, v int) {
	*i = v
}

func test6() {
	m1 := perm(1, 2) + perm(1, 2)
	assert m1 == writePerm

	m2 := perm(1, 2) + perm(1, 2)
	assert m2 == writePerm

	m3 := perm(1, 2) + perm(1, 2)
	assert m3 == writePerm

	// the following is interpreted as an int expression (the default type when no type is provided).
	// as such, it yields the value `0`
	m4 := 1/2 + 1/2
	assert m4 == 0

	ghost var m5 perm = perm(1, 2)
	assert m5 + perm(1, 2) == writePerm
}

func test7() {
	assert int8(1)/int8(1) == int8(1)
}

func test8() {
	assert getPerm() == perm(3, 4)
	assert getPerm() != noPerm
	assert getPerm() != writePerm
}

ghost pure func getPerm() perm {
	return perm(3, 4)
}

// perm(1, 2) / 4 gives perm(1, 8): dividing a fractional permission by 4 quarters it
requires acc(i, perm(1, 8))
ensures acc(i, perm(1, 2) / 4)
func test9(i *int) { }
