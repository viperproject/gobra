package pkg

import "math"

// bound so that the assignment of the mathematical length to the
// bounded-int variable n is provably exact
requires len(s) <= math.MaxInt64
func test1(s []int) {
  n := len(s)
  assert 0 <= n
}

func test2() {
  var s []bool
  assert len(s) == 0 
}

ensures len(s) == 0
func test3() (s []int) {
}

requires 0 < len(s)
func test4(s []int) {
  assert s != nil
}
