package ints

// Regression test: integer literal subexpressions in binary expressions must receive the
// concrete type imposed by the surrounding context rather than the internal unbounded-int
// type (UNTYPED_INT_CONST). The fix ensures that both operands of `1 + 2` are typed as
// `int` (or the relevant concrete type) when a typed context is present.

func testBinaryExprLiteralTypes() {
	// Both `1` and `2` should be typed as `int` here.
	var a int = 1 + 2
	assert(a == 3)

	// Both `1` and `2` should be typed as `int8` here.
	var b int8 = 1 + 2
	assert(b == 3)

	// Nested binary expressions: all literals should get `int`.
	var c int = 1 + 2 + 3
	assert(c == 6)
}

func testShiftExprLiteralTypes() {
	// The left operand of a shift follows the context type.
	var d int = 1 << 2
	assert(d == 4)
}

func testTypedSiblingLiteralTypes() {
	// When a literal appears next to a typed operand, it should receive that operand's type.
	var x uint8 = 1
	var y uint8 = 1 + x  // `1` should get type uint8 from sibling `x`
	assert(y == 2)

	var a int8 = 3
	var b int8 = 2 + a  // `2` should get type int8 from sibling `a`
	assert(b == 5)
}

type S struct { field uint8 }

ensures ret == 42
func getUint8() (ret uint8) { ret = 42 }

// Value receiver: no heap permissions needed.
func (s S) method() uint8 { return s.field }

func testFunctionCallSibling() {
	// getUint8() + 1: `1` should get type uint8 from getUint8()'s return type
	x := getUint8() + 1
	assert(x == 43)
}

// Return value captures the result; no assertion about an unknown value needed.
func testMethodCallSibling(s S) (res uint8) {
	// s.method() + 1: `1` should get type uint8 from the method's return type
	res = s.method() + 1
}

func testFieldAccessSibling(s S) (res uint8) {
	// s.field + 1: `1` should get type uint8 from the field's type
	res = s.field + 1
}
