package assignsuchthatpredicateinrhs

// A predicate instance is a resource, not a pure expression. Using one in the
// RHS must be rejected by the purity check.

pred P(x int)

func f() {
	//:: ExpectedOutput(type_error)
	var x int |= P(x)
}
