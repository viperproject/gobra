package main

// this testcase checks whether the correct proof obligations are used for checking behavioral subtyping of an imported
// interface that specifies termination measures for the interface members.

// ##(-I ./)
import f "foo"

type FooImpl2 struct{}

// Rejected: pure function without termination measure (wellFoundedIfNeeded).
// Note: Fn()'s methodImplMightImplementSpec error is masked because this error fills
// partialRes first, causing wellImplementationProofs to be skipped.
//:: ExpectedOutput(type_error)
pure func (foo FooImpl2) PureFn() bool {
    return true
}

// The methodImplMightImplementSpec error for Fn() is masked by PureFn()'s
// wellFoundedIfNeeded error (wellImplementationProofs is skipped when partialRes is non-empty).
func (foo FooImpl2) Fn() bool {
    return true
}

func triggerSubtype() f.Foo {
    return FooImpl2{}
}
