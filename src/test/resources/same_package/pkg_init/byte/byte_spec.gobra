package byte

pred StaticInv() {
	acc(&byteCache, _) &&
	(forall j, k integer :: 0 <= j && j < k && k <= 255  ==>
		byteCache[j] != byteCache[k]) &&
	(forall i integer :: 0 <= i && i <= 255 ==>
		acc(byteCache[i], _) && byteCache[i].value == byte(i))
}

pred (b *Byte) Mem() {
	acc(b, _)
}
