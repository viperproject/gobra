package assignsuchthatwildcardperm

// A wildcard permission `acc(p, _)` is a resource. The RHS must be pure, so
// it must be rejected.

func f() {
	p := new(int)
	//:: ExpectedOutput(type_error)
	var x int |= acc(p, _) && *p == x
	_ = x
}
