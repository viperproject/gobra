package permConstructorInteger

ghost
decreases
pure func fromInteger(n integer) perm {
    return perm(n, 1)
}

ghost
decreases
pure func fromConvertedInt(n int) perm {
    return perm(integer(n), 1)
}

ghost
decreases
pure func boundedNumeratorRejected(n int) perm {
    //:: ExpectedOutput(type_error)
    return perm(n, 1)
}

ghost
decreases
pure func boundedDenominatorRejected(n int) perm {
    //:: ExpectedOutput(type_error)
    return perm(1, n)
}
