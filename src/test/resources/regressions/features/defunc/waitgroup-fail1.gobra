package pkg

import "sync"

func problemWithCollect() {
	fold acc(PredTrue!<!>(), perm(1, 2))
	fold sync.CollectFractions(seq[pred()]{ PredTrue!<!> }, seq[perm]{perm(1, 2)})
	assert sync.CollectFractions(seq[pred()]{ PredTrue!<!> }, seq[perm]{perm(1, 2)})
	assert sync.CollectFractions(seq[pred()]{ PredTrue!<!> }, seq[perm]{perm(2, 4)})
	//:: ExpectedOutput(assert_error:permission_error)
	assert sync.CollectFractions(seq[pred()]{ PredTrue!<!> }, seq[perm]{perm(3, 4)})
}