package pkg

type A interface {
	decreases
	pure f() int
}

type B interface {
	A
	decreases
	pure g() int
}

type X struct {
	x int
}

decreases
pure func (self *X) f() int {
	return 0
}

type Y struct {
	y int
}

decreases
pure func (self *Y) f() int {
	return 1
}

decreases
pure func (self *Y) g() int {
	return 2
}

(*X) implements A

(*Y) implements B

func test() {
	y := &Y{4}
	var b B = y
	assert y.f() == 1
	assert b.g() == 2
	assert b.f() == 1
}
