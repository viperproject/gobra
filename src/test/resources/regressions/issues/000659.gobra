// The quantified permission `forall i int :: acc(s.nodes[i])` is no longer provably injective
// under the sound bounded-integer encoding, so the fold fails before the expected assertion.
// Restore the previous unbounded-integer encoding, under which this program verifies as intended.
// ##(--unboundedIntegers)
package issue659

type Node struct {
    ok     bool
}

pred (s *Set)mem(){
    acc(s) &&
    acc(s.nodes) &&
    forall i int:: i elem domain(s.nodes) ==> acc(s.nodes[i])
}

type Set struct {
    nodes map[int]*Node
}

requires s.mem()
requires acc(n)
requires !(k elem unfolding s.mem() in domain(s.nodes))
func (s *Set) add2(n *Node, k int){
    unfold s.mem()
    _,ok := s.nodes[0];
    if ok {
        s.nodes[k] = n
        fold s.mem()
        //:: ExpectedOutput(assert_error:assertion_error)
        assert false // should fail
        return
    }
}
