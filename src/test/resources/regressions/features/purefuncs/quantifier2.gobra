package pkg;

pure func test(a int)(res int){
    return a+1
}

// The quantified i is a mathematical integer, so it must be bounded to the
// int64 range on both sides for the call test(i) and i+1 to be provably exact.
ensures forall i int :: -9223372036854775808 <= i && i < 9223372036854775807 ==> i == test(i)-1
func client(){}
