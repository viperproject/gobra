package issue001043

pred P()

requires P()
func test() {
	package P() --* P() {}
}

pred Q(x int)

requires Q{_}(42)
ensures Q{_}(42)
func testPartiallyAppliedPredicate() {
	package true --* Q{_}(42) {}
	apply true --* Q{_}(42)
}
