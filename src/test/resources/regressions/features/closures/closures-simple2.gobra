package closuresSimple2

import "math"

ghost
requires p.inv() && a >= 0
ensures p.inv() && r >= 0
func pos(ghost p interface{pred inv();}, a int) (r int)

type proof1 struct { x *int }
pred (p proof1) inv() { acc(p.x) && *p.x >= 0 }

func main() {
	x@ := 0
	c := preserves acc(&x)
		 // guarded increment: the sum is only performed (and exact) when it provably fits int
		 ensures old(x) >= 0 && n >= 0 ==> x >= 0
		 ensures m == x
		 func f(n int) (m int) {
            if n >= 0 && x <= math.MaxInt64 - n { // guard against overflow
                x += n
            }
		    return x
         }

	proof c implements pos{p: proof1{&x}} {
		unfold proof1{&x}.inv()
		r = c(a) as f
		fold proof1{&x}.inv()
	}

	fold proof1{&x}.inv()

	hof(c, proof1{&x})
}

preserves p.inv() && c implements pos{p}
func hof(c func(int) int, ghost p interface{pred inv()}) {
	v := c(42) as pos{p: p}
	assert v >= 0
}
