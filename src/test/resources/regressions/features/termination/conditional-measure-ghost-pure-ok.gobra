package conditional_measure_ghost_pure_ok

// Unconditional termination measures remain accepted on ghost / pure / interface members.

ghost
requires n >= 0
decreases n
func ghostFunc(n int) int {
	if n == 0 {
		return 0
	}
	return ghostFunc(n - 1)
}

ghost
requires n >= 0
decreases n
pure func pureFunc(n int) int {
	return n == 0 ? 0 : pureFunc(n - 1)
}

type T struct{}

ghost
requires n >= 0
decreases n
func (t T) ghostMethod(n int) int {
	if n == 0 {
		return 0
	}
	return t.ghostMethod(n - 1)
}

ghost
requires n >= 0
decreases n
pure func (t T) pureMethod(n int) int {
	return n == 0 ? 0 : t.pureMethod(n - 1)
}

type GhostItf interface {
	ghost
	decreases n
	GhostMethod(n int) int
}

type PureItf interface {
	decreases n
	pure PureMethod(n int) int
}
