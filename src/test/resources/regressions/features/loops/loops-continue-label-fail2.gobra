package pkg

func count_even(n int) (res int) {
	invariant 0 <= i && i <= 10
	decreases 10 - i
	for i := 0; i < 10; i++ {
	label1:
		invariant 0 <= j && j <= 10
		decreases 10 - j
		for j := 0; j < 10; j++ {
			invariant 0 <= k && k <= 10
			decreases 10 - k
			for k := 0; k < 10; k++ {
			label2:
				invariant 0 <= l && l <= 10
				decreases 10 - l
				for l := 0; l < 10; l++ {
					if k > 5 {
						continue label1
					}
					if l > 5 {
						continue label2
					}
				}
			}
		}
	}
	//:: ExpectedOutput(assert_error)
	assert false
}
