package pkg


type foo interface {
	bar
	f()
}

type bar interface {
	decreases
	g()

	pure
	decreases
	h() int
}

type test int

func (x test) f()

// The methodImplMightImplementSpec error for g() is masked by h()'s wellFoundedIfNeeded error,
// because wellImplementationProofs is skipped when partialRes is non-empty.
func (x test) g()

// Rejected: pure function without termination measure (wellFoundedIfNeeded).
//:: ExpectedOutput(type_error)
pure func (x test) h() int

test implements foo