
func testBranches(a bool){
    @dependencyInfo("assumptionType:SourceCode, label:L0, expectedDependencies:[]")
    x := 0
    if(@dependencyInfo("assumptionType:PathCondition, label:L1, expectedDependencies:[]")(a)){
        @dependencyInfo("assumptionType:SourceCode, label:L2, expectedDependencies:[]")
        x = 1
        @dependencyInfo("assertionType:Explicit, label:L3, expectedDependencies:[L1]")
        assert a
    }else{
        @dependencyInfo("assumptionType:SourceCode, label:L4, expectedDependencies:[L0]")
        x = 2
        @dependencyInfo("assertionType:Explicit, label:L5, expectedDependencies:[L1]")
        assert !a
    }
    @dependencyInfo("assertionType:Explicit, label:L6, expectedDependencies:[L2, L4, L1, L3]")
    assert x > 0
}


requires @dependencyInfo("assumptionType:Precondition, label:L7, expectedDependencies:[]")(a > 0)
ensures @dependencyInfo("assertionType:ImplicitPostcondition, label:L8, expectedDependencies:[L7,L9,L9b]")(res > 0)
func bar(a int) (res int){
    if(@dependencyInfo("assumptionType:PathCondition, label:L9, expectedDependencies:[]")(a > 0)){
        return @dependencyInfo("assumptionType:SourceCode, label:L9b, expectedDependencies:[]")(a)
    } else {
        @dependencyInfo("assertionType:Explicit, label:L10, expectedDependencies:[L7,L9]")
        assert false
    }
}


requires @dependencyInfo("assumptionType:Precondition, label:L11, expectedDependencies:[]")(a >= 0)
requires @dependencyInfo("assumptionType:Precondition, label:L12, expectedDependencies:[]")(a < 100)
ensures @dependencyInfo("assertionType:ImplicitPostcondition, label:L13, expectedDependencies:[L11, L14]")(res > 0)
pure func add_one(a int) (res int){
    return @dependencyInfo("assumptionType:SourceCode, label:L14, expectedDependencies:[]")(a + 1)
}

const TEN = @dependencyInfo("assumptionType:SourceCode, label:L15, expectedDependencies:[]")(10)

func client() {
    @dependencyInfo("assumptionType:SourceCode, label:L16, expectedDependencies:[]")
    a := 30

    @dependencyInfo("assumptionType:SourceCode, label:L17, expectedDependencies:[L16]")
    res := add_one(a)
    @dependencyInfo("assertionType:Explicit, label:L18, expectedDependencies:[L13,L11,L14,L17,L16]")
    assert res > 0


    @dependencyInfo("assumptionType:SourceCode, label:L19, expectedDependencies:[L16]")
    res2 := bar(a)
    @dependencyInfo("assertionType:Explicit, label:L20, expectedDependencies:[L16,L19,L8,L7,L9,L9b]")
    assert res2 > 0

    @dependencyInfo("assertionType:Explicit, label:L21, expectedDependencies:[L15]")
    assert TEN == 10
}