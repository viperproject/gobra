package main;

type Cell struct {
    a int;
    b int;
};

requires c.a < 9223372036854775807; // bound so that x+1 provably does not overflow
func test1(c Cell) () {
    q@ := c
    x := q.a;
    p := &(q.a);
    *p = x+1;
    y := q.a;
    assert x != y;
};

func test2() (c Cell) {
    q@ := c
    x := q.a;
    p := &(q.a);
    *p = x+1;
    y := q.a;
    assert x != y;
};
