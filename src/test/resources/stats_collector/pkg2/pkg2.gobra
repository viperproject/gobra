package pkg2

import "pkg1"

type Rect struct {
  width int
  height int
}

pred (r *Rect) mem() {
  acc(r, perm(1, 2))
}

requires acc(r, perm(1, 2))
pure func (r *Rect) Size() bool {
  // The upper bounds let the verifier prove that computing the area does not
  // overflow (with Gobra's sound bounded-integer semantics, `width * height`
  // is only known exactly when the mathematical result is in range).
  return r.width > 0 && r.height > 0 && r.width < 100 && r.height < 100
}

requires acc(r, perm(1, 2)) && r.Size()
ensures  acc(r, perm(1, 2)) && ret > 0
func (r *Rect) Area() (ret int) {
  return r.width * r.height
}

(*Rect) implements pkg1.Shape {
  pure (r *Rect) Size() bool {
    return unfolding acc(r.mem(), perm(1, 2)) in r.Size()
  }
  (r *Rect) Area() (ret int) {
    unfold r.mem()
    ret = r.Area()
    fold r.mem()
  }
}

type Circle struct {
  radius int
}

pred (c *Circle) mem() {
  acc(c, perm(1, 2))
}

requires acc(c, perm(1, 2))
pure func (c *Circle) Size() bool {
  // Upper bound for overflow-free area computation; see Rect.Size.
  return c.radius > 0 && c.radius < 100
}

requires acc(c, perm(1, 2)) && c.Size()
ensures acc(c, perm(1, 2)) && ret > 0
func (c *Circle) Area() (ret int) {
  // constant-first grouping: (3 * r) * r keeps every intermediate bound linear for
  // the verifier; (r * r) * 3 would need a nonlinear bound on the r*r intermediate
  return 3 * c.radius * c.radius
}

(*Circle) implements pkg1.Shape {
  pure (c *Circle) Size() bool {
    return unfolding acc(c.mem(), perm(1, 2)) in c.Size()
  }

  (c *Circle) Area() (ret int) {
    unfold c.mem()
    ret = c.Area()
    fold c.mem()
  }
}
